{
  "name": "nucleus-website",
  "version": "1.0.2",
  "description": "Nucleus Consultant — Premium static website with dynamic blog system",
  "type": "module",
  "scripts": {
    "start": "npx serve . -l 3000",
    "dev": "live-server --port=3000 --open=index.html --ignore=node_modules",
    "blog": "live-server --port=3000 --open=blog.html --ignore=node_modules",
    "admin": "live-server --port=3000 --open=admin.html --ignore=node_modules",
    "lint:html": "npx htmlhint **/*.html"
  },
  "keywords": [
    "nucleus",
    "consultant",
    "static-site"
  ],
  "author": "Nucleus Consultant",
  "license": "ISC",
  "devDependencies": {
    "live-server": "^1.2.2"
  }
}
